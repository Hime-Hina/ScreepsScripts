{
  "name": "screeps-scripts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript Screeps AI codebase rebuilt with Trellis and TDD.",
  "license": "MIT",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "rollup --config rollup.config.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm format && pnpm test:coverage && pnpm test:system && pnpm test:bundle",
    "deploy:ptr:screeps": "pnpm check && pnpm build && node scripts/screeps/deploy-ptr.mjs",
    "deploy:screeps": "pnpm check && pnpm build && node scripts/screeps/deploy.mjs",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "found:ptr-room:screeps": "node scripts/screeps/found-ptr-room.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "rollback:screeps": "node scripts/screeps/rollback.mjs",
    "rollback:ptr:screeps": "node scripts/screeps/rollback-ptr.mjs",
    "scout:screeps": "node scripts/screeps/scout-rooms.mjs",
    "ops:event-bridge:screeps": "node scripts/screeps/ops-event-bridge.mjs",
    "ops:event-bridge:dry-run:screeps": "node scripts/screeps/ops-event-bridge-dry-run.mjs",
    "ops:event-notify:screeps": "node scripts/screeps/ops-event-notifier.mjs",
    "ops:event-wake-hermes:screeps": "node scripts/screeps/ops-event-waker.mjs",
    "ops:event-email-fallback:screeps": "node scripts/screeps/ops-event-email-fallback.mjs",
    "status:live:screeps": "node scripts/screeps/live-survival-status.mjs --shard shard1 --room W51N21",
    "status:role-recovery:screeps": "node scripts/screeps/role-recovery-status.mjs --shard shard1 --room W51N21",
    "test": "vitest run test/unit test/integration",
    "test:bundle": "pnpm build && vitest run test/e2e",
    "test:integration": "vitest run test/integration",
    "test:screeps-server": "node scripts/screeps-server/run-suite.mjs smoke",
    "test:system": "pnpm build && vitest run test/system",
    "test:unit": "vitest run test/unit",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage test/unit test/integration",
    "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.vitest.json --noEmit && tsc --project tsconfig.node.json --noEmit",
    "verify:live:screeps": "pnpm build && node scripts/screeps/verify-live.mjs",
    "verify:ptr:screeps": "pnpm build && node scripts/screeps/verify-ptr.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.9.2",
    "@types/screeps": "^3.4.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rollup": "^4.61.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "he": "^1.2.0"
  }
}
